# syntax=docker/dockerfile:1

FROM node:20-alpine AS build
WORKDIR /app

ARG VITE_PARENT_APP_URL
ARG VITE_CAREGIVER_APP_URL
ARG VITE_COORDINATOR_PORTAL_URL
ARG VITE_PLAY_STORE_PARENT
ARG VITE_PLAY_STORE_CAREGIVER
ARG VITE_APP_STORE_PARENT
ARG VITE_APP_STORE_CAREGIVER

ENV VITE_PARENT_APP_URL=$VITE_PARENT_APP_URL
ENV VITE_CAREGIVER_APP_URL=$VITE_CAREGIVER_APP_URL
ENV VITE_COORDINATOR_PORTAL_URL=$VITE_COORDINATOR_PORTAL_URL
ENV VITE_PLAY_STORE_PARENT=$VITE_PLAY_STORE_PARENT
ENV VITE_PLAY_STORE_CAREGIVER=$VITE_PLAY_STORE_CAREGIVER
ENV VITE_APP_STORE_PARENT=$VITE_APP_STORE_PARENT
ENV VITE_APP_STORE_CAREGIVER=$VITE_APP_STORE_CAREGIVER

COPY package.json package-lock.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM nginx:1.27-alpine AS runtime
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
  CMD wget -qO- http://127.0.0.1/ || exit 1
