# Copy to .env on the VPS and fill in all secrets before first deploy.
# docker compose --env-file .env up -d --build

# --- Host nginx upstream ports (localhost only) ---
STAFFERA_API_PORT=15000
STAFFERA_WEBSITE_PORT=15001
STAFFERA_AGENT_PORT=15002

# --- Public URLs (used at build time for frontends + CORS) ---
# Replace staffera.example.com with your real domains
WEBSITE_DOMAIN=staffera.example.com
AGENT_DOMAIN=agent.staffera.example.com
API_DOMAIN=api.staffera.example.com

VITE_API_BASE_URL=https://api.staffera.example.com/api/v1
VITE_API_HOST=https://api.staffera.example.com
VITE_AGENT_PORTAL_URL=https://agent.staffera.example.com
VITE_HOUSE_OWNER_APP_URL=#
VITE_SERVANT_APP_URL=#
VITE_PLAY_STORE_HOUSE_OWNER=#
VITE_PLAY_STORE_SERVANT=#
VITE_APP_STORE_HOUSE_OWNER=#
VITE_APP_STORE_SERVANT=#

# Comma-separated browser origins allowed by the API (website + agent portal)
CLIENT_URL=https://staffera.example.com,https://agent.staffera.example.com

# --- PostgreSQL ---
POSTGRES_USER=staffera
POSTGRES_PASSWORD=change_me_strong_db_password
POSTGRES_DB=staffera
# Required when password has @ # : / etc. Encode @ as %40, # as %23, : as %3A
# DATABASE_URL=postgresql://staffera:your%40password@postgres:5432/staffera

# --- Auth (min 32 chars each) ---
JWT_SECRET=change_me_jwt_secret_at_least_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# --- Email (optional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Push notifications (optional) ---
FCM_SERVER_KEY=

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=
GOOGLE_MAP_ID=

# --- SMS (production: use msg91 or twilio; set SMS_ALLOW_DEV_OTP=false) ---
SMS_PROVIDER=msg91
SMS_DEFAULT_COUNTRY_CODE=91
MSG91_AUTH_KEY=
MSG91_SENDER_ID=STFFRA
MSG91_ROUTE=4
MSG91_TEMPLATE_ID=
SMS_ALLOW_DEV_OTP=false

# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=

# Default service radius (km) for new agents; admin can set per-agent (e.g. 5, 10)
SERVANT_AGENT_RADIUS_KM=3
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=800
